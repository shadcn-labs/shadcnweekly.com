---
import { Font } from "astro:assets";
import { SEO } from "astro-seo";
import Analytics from "@vercel/analytics/astro";
import { SITE } from "@/constants/site";
import { ROUTES } from "@/constants/routes";
import {
  buildOgImagePath,
  OG_IMAGE_HEIGHT,
  OG_IMAGE_TYPE,
  OG_IMAGE_WIDTH,
} from "@/lib/og";

const DEFAULT_HEADLINE = "Stay up-to-date on shadcn";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  imageWidth?: number;
  imageHeight?: number;
  imageType?: string;
  canonical?: string;
  noindex?: boolean;
  nofollow?: boolean;
  ogType?: "website" | "article";
}

const {
  title = DEFAULT_HEADLINE,
  description = SITE.DESCRIPTION.LONG,
  image,
  imageAlt = `${SITE.NAME} - ${DEFAULT_HEADLINE}`,
  imageWidth = OG_IMAGE_WIDTH,
  imageHeight = OG_IMAGE_HEIGHT,
  imageType = OG_IMAGE_TYPE,
  canonical,
  noindex = false,
  nofollow = false,
  ogType = "website",
} = Astro.props;

const canonicalURL = canonical
  ? new URL(canonical, SITE.URL)
  : new URL(Astro.url.pathname, SITE.URL);

const isHome = Astro.url.pathname === ROUTES.HOME;
const pageTitle = isHome ? title : `${title} | ${SITE.NAME}`;

const ogImagePath =
  image ??
  buildOgImagePath({
    description,
    title: isHome ? DEFAULT_HEADLINE : title,
  });

const ogImageURL = new URL(ogImagePath, SITE.URL).href;
---

<meta charset="utf-8" />
<link rel="icon" type="image/svg+xml" href={ROUTES.FAVICON} />
<meta name="viewport" content="width=device-width" />
<meta name="generator" content={Astro.generator} />
<meta name="theme-color" content="#000000" />

<SEO
  title={pageTitle}
  description={description}
  canonical={canonicalURL.href}
  noindex={noindex}
  nofollow={nofollow}
  robotsExtras="max-snippet:-1, max-image-preview:large, max-video-preview:-1"
  openGraph={{
    basic: {
      title: pageTitle,
      type: ogType,
      image: ogImageURL,
      url: canonicalURL.href,
    },
    optional: {
      description,
      siteName: SITE.NAME,
      locale: SITE.LOCALE,
    },
    image: {
      alt: imageAlt,
      width: imageWidth,
      height: imageHeight,
      type: imageType,
    },
  }}
  twitter={{
    card: "summary_large_image",
    site: SITE.AUTHOR.TWITTER,
    title: pageTitle,
    description,
    image: ogImageURL,
    imageAlt,
  }}
  extend={{
    link: [{ rel: "sitemap", href: ROUTES.SITEMAP }],
  }}
/>

<slot />

<Font cssVariable="--font-sans" preload />
<Analytics />

<script
  is:inline
  type="application/ld+json"
  set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Organization",
    name: SITE.NAME,
    url: SITE.URL,
    logo: `${SITE.URL}${ROUTES.FAVICON}`,
    description: SITE.DESCRIPTION.LONG,
    sameAs: [`https://x.com/${SITE.AUTHOR.TWITTER.replace("@", "")}`],
  })}
/>

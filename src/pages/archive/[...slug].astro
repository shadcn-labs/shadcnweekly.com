---
import Layout from "@/layouts/site.astro";
import { ArrowLeftIcon } from "lucide-react";
import { getCollection, render } from "astro:content";
import { SITE } from "@/constants/site";
import { ROUTES } from "@/constants/routes";

export const prerender = true;

export const getStaticPaths = async () => {
  const issues = await getCollection("archive");
  return issues.map((issue) => ({
    params: { slug: issue.id },
    props: { issue },
  }));
};

const { issue } = Astro.props;
const { Content } = await render(issue);

const formatDate = (date: Date) =>
  date.toLocaleDateString("en-US", {
    day: "numeric",
    month: "long",
    year: "numeric",
  });
---

<Layout
  title={`${issue.data.title} - ${SITE.NAME}`}
  description={issue.data.description}
>
  <div class="flex flex-1 flex-col items-center py-16">
    <div class="flex max-w-2xl flex-col gap-6">
      <div>
        <a
          href={ROUTES.ARCHIVE}
          class="inline-flex text-sm items-center gap-2 text-muted-foreground transition-colors hover:text-foreground"
        >
          <ArrowLeftIcon className="size-4" />
          Back to archive
        </a>
      </div>

      <div class="flex flex-col gap-2">
        <span class="text-sm text-muted-foreground">
          Issue #{issue.data.issue}
        </span>
        <h1 class="text-3xl font-semibold tracking-tight">
          {issue.data.title}
        </h1>
        <time class="text-sm text-muted-foreground/60">
          {formatDate(issue.data.date)}
        </time>
      </div>

      <div
        class="prose prose-neutral dark:prose-invert flex flex-col gap-4 text-base leading-relaxed text-muted-foreground"
      >
        <Content />
      </div>
    </div>
  </div>
</Layout>

---
import Layout from "@/layouts/site.astro";
import { ArrowLeftIcon } from "lucide-react";
import {
  Card,
  CardHeader,
  CardTitle,
  CardContent,
  CardFooter,
} from "@/components/ui/card";
import { Badge } from "@/components/ui/badge";
import { buttonVariants } from "@/components/ui/button";
import { SponsorModal } from "@/components/sponsor-modal";
import { NEXT_ISSUE_DATE, SITE } from "@/constants/site";
import { ROUTES } from "@/constants/routes";
import { SPONSOR_PLACEMENTS } from "@/constants/sponsor";
---

<Layout
  title="Sponsor"
  description={`Sponsor ${SITE.NAME} and reach thousands of shadcn developers, designers, and builders every week.`}
>
  <script
    is:inline
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      itemListElement: [
        {
          "@type": "ListItem",
          position: 1,
          name: "Home",
          item: SITE.URL,
        },
        {
          "@type": "ListItem",
          position: 2,
          name: "Sponsor",
          item: `${SITE.URL}${ROUTES.SPONSOR}`,
        },
      ],
    })}
  />
  <div class="flex flex-1 flex-col items-center py-16">
    <div class="flex max-w-2xl flex-col gap-8">
      <div>
        <a
          href={ROUTES.HOME}
          class="inline-flex text-sm items-center gap-2 text-muted-foreground transition-colors hover:text-foreground"
        >
          <ArrowLeftIcon className="size-4" />
          Back to home
        </a>
      </div>

      <div class="flex flex-col gap-3">
        <h1 class="text-3xl font-semibold tracking-tight">Sponsor</h1>
        <p class="text-base text-muted-foreground">
          Put your product, library, or service in front of developers who
          actually build with shadcn/ui every day.
        </p>
      </div>

      <div class="flex flex-col gap-8">
        <div class="flex flex-col gap-3">
          <h2 class="text-xl font-semibold">
            Why sponsor {SITE.NAME}?
          </h2>
          <div
            class="flex flex-col gap-3 leading-relaxed text-muted-foreground"
          >
            <p>
              {SITE.NAME} launches on{" "}
              <span class="font-medium text-foreground">{NEXT_ISSUE_DATE}</span
              >. It's a curated newsletter for the shadcn ecosystem — new
              releases, community projects, tutorials, and tools. Every link is
              hand-picked, every word is written by me.
            </p>
            <p>
              This isn't a generic dev blast with 100k subscribers who never
              open it. The audience here is builders — people who read the
              changelog, try new component libraries on weekends, and care about
              clean UI code. If your product speaks to that crowd, this is the
              place to be.
            </p>
            <p>
              I'm keeping sponsorships limited and the pricing fair. No
              programmatic ad slots, no "sponsored by" walls. If I feature you,
              it's because I think the audience would genuinely find it useful.
            </p>
          </div>
        </div>

        <div class="flex flex-col gap-4">
          <h2 class="text-xl font-semibold">Placements</h2>

          <div class="flex flex-col gap-4">
            {
              SPONSOR_PLACEMENTS.map((placement) => (
                <Card className="rounded-lg border border-border ring-0">
                  <CardHeader>
                    <div class="flex items-center gap-3">
                      <CardTitle>{placement.title}</CardTitle>
                      {placement.tag === "Most Performing" && (
                        <Badge variant="warning">{placement.tag}</Badge>
                      )}
                      {placement.tag === "Best Value" && (
                        <Badge variant="success">{placement.tag}</Badge>
                      )}
                    </div>
                  </CardHeader>
                  <CardContent>
                    <p class="text-sm leading-relaxed text-muted-foreground">
                      {placement.description}
                    </p>
                  </CardContent>
                  <CardFooter>
                    <SponsorModal
                      client:load
                      defaultPlacement={placement.title}
                    >
                      <span class={buttonVariants({ variant: "default" })}>
                        Book — ${placement.price}
                      </span>
                    </SponsorModal>
                  </CardFooter>
                </Card>
              ))
            }
          </div>
          <p class="text-xs text-muted-foreground/60">
            All rates in USD. Payment processed securely via <a
              href="https://creem.com"
              class="link">Creem</a
            >.
          </p>
        </div>
      </div>
    </div>
  </div>
</Layout>

---
import { mdxComponents } from "@/components/mdx";
import ArchiveTogetherWith from "@/components/archive-together-with.astro";
import Layout from "@/layouts/site.astro";
import { ArrowLeftIcon } from "lucide-react";
import { getCollection, render } from "astro:content";
import { SITE } from "@/constants/site";
import { ROUTES } from "@/constants/routes";
import { LINKS } from "@/constants/links";
import { OG_IMAGE_HEIGHT, OG_IMAGE_TYPE, OG_IMAGE_WIDTH } from "@/lib/og";

export const prerender = true;

export const getStaticPaths = async () => {
  const issues = await getCollection("archive");
  return issues.map((issue) => ({
    params: { slug: issue.id },
    props: { issue },
  }));
};

const { issue } = Astro.props;
const { Content } = await render(issue);
const imageSlug = issue.id.split("/").map(encodeURIComponent).join("/");

const formattedDate = issue.data.date.toLocaleDateString("en-US", {
  day: "numeric",
  month: "long",
  year: "numeric",
});
---

<Layout
  title={issue.data.title}
  description={issue.data.description}
  image={`/og/issues/${imageSlug}.png`}
  imageAlt={`${issue.data.title} — Shadcn Weekly Issue #${issue.data.issue}`}
  imageWidth={OG_IMAGE_WIDTH}
  imageHeight={OG_IMAGE_HEIGHT}
  imageType={OG_IMAGE_TYPE}
  ogType="article"
>
  <script
    is:inline
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "NewsArticle",
      headline: issue.data.title,
      description: issue.data.description,
      datePublished: issue.data.date.toISOString(),
      image: `${SITE.URL}${ROUTES.OG}${ROUTES.ISSUES}/${imageSlug}.png`,
      mainEntityOfPage: `${SITE.URL}${ROUTES.ISSUES}/${issue.id}`,
      publisher: {
        "@type": "Organization",
        name: SITE.NAME,
        url: SITE.URL,
      },
    })}
  />

  <div class="flex flex-1 flex-col items-center py-16">
    <div class="flex w-full max-w-2xl flex-col gap-8">
      <div>
        <a
          href={ROUTES.ISSUES}
          class="inline-flex items-center gap-2 text-sm text-muted-foreground transition-colors hover:text-foreground"
        >
          <ArrowLeftIcon className="size-4" />
          Back to archive
        </a>
      </div>

      <header class="flex flex-col items-center gap-6 text-center">
        <p class="text-sm text-muted-foreground">
          <span>Issue #{issue.data.issue}</span>
          <span aria-hidden="true" class="mx-1">·</span>
          <time datetime={issue.data.date.toISOString()}>{formattedDate}</time>
        </p>

        <h1
          class="text-3xl font-semibold tracking-tight text-balance sm:text-4xl"
        >
          {issue.data.title}
        </h1>

        <hr class="w-full border-border" />

        {
          issue.data.sponsor ? (
            <ArchiveTogetherWith website={issue.data.sponsor} />
          ) : null
        }
      </header>

      <div class="typeset typeset-issue text-left">
        <Content components={mdxComponents} />
        <div>
          <p>
            Have a link you want to share? Send me an email at{" "}
            <a href={`mailto:${LINKS.EMAIL}`}>{LINKS.EMAIL}</a>
          </p>
          <p class="text-muted-foreground not-typeset">
            All submissions are appreciated.
          </p>
          <p class="text-muted-foreground">👋 See you next week!</p>
        </div>
      </div>
    </div>
  </div>
</Layout>

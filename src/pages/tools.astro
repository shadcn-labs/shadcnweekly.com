---
import Layout from "@/layouts/site.astro";
import { ArrowLeftIcon, Clock } from "lucide-react";
import { NEXT_ISSUE_NUMBER, NEXT_ISSUE_DATE, SITE } from "@/constants/site";
import { ROUTES } from "@/constants/routes";
---

<Layout
  title="Tools"
  description={`Hand-picked shadcn tools, libraries, and resources curated by ${SITE.NAME}. Discover the best tools for your next project.`}
>
  <script
    is:inline
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      itemListElement: [
        {
          "@type": "ListItem",
          position: 1,
          name: "Home",
          item: SITE.URL,
        },
        {
          "@type": "ListItem",
          position: 2,
          name: "Tools",
          item: `${SITE.URL}${ROUTES.TOOLS}`,
        },
      ],
    })}
  />
  <div class="flex flex-1 flex-col items-center py-16">
    <div class="flex w-full max-w-3xl flex-col gap-8">
      <div>
        <a
          href={ROUTES.HOME}
          class="inline-flex text-sm items-center gap-2 text-muted-foreground transition-colors hover:text-foreground"
        >
          <ArrowLeftIcon className="size-4" />
          Back to home
        </a>
      </div>

      <div class="flex flex-col gap-2">
        <h1 class="text-3xl font-semibold tracking-tight">Tools</h1>
        <p class="text-base text-muted-foreground">
          Hand-picked tools, libraries, and resources from the shadcn ecosystem.
          Updated weekly.
        </p>
      </div>

      <div
        class="flex flex-col items-center justify-center gap-4 rounded-lg border border-dashed border-border py-20 px-4 text-center"
      >
        <div
          class="flex size-12 items-center justify-center rounded-full bg-muted"
        >
          <Clock className="size-6 text-muted-foreground" />
        </div>
        <div class="flex flex-col gap-1">
          <h2 class="text-lg font-semibold">Coming Soon</h2>
          <p class="max-w-sm text-sm text-muted-foreground text-balance">
            Our curated collection of shadcn tools drops with Issue #{
              NEXT_ISSUE_NUMBER
            } on{" "}
            <span class="font-medium text-foreground">
              {NEXT_ISSUE_DATE}
            </span>
            . We're putting together the most useful libraries, components, and developer
            tools so you don't have to dig through the noise.
          </p>
        </div>
        <p class="text-xs text-muted-foreground/60">
          Subscribe to get the best tools delivered to your inbox.
        </p>
      </div>
    </div>
  </div>
</Layout>

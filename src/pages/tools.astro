---
import { getCollection } from "astro:content";
import Layout from "@/layouts/site.astro";
import ToolCard from "@/components/tool-card.astro";
import { ArrowLeftIcon } from "lucide-react";
import { SITE } from "@/constants/site";
import { ROUTES } from "@/constants/routes";

const toolsCollection = await getCollection("tools");
const tools = toolsCollection.toSorted(
  (a, b) => b.data.issue - a.data.issue || a.data.title.localeCompare(b.data.title),
);
---

<Layout
  title="Tools"
  description={`Hand-picked shadcn tools, libraries, and resources curated by ${SITE.NAME}. Discover the best tools for your next project.`}
>
  <script
    is:inline
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      itemListElement: [
        {
          "@type": "ListItem",
          position: 1,
          name: "Home",
          item: SITE.URL,
        },
        {
          "@type": "ListItem",
          position: 2,
          name: "Tools",
          item: `${SITE.URL}${ROUTES.TOOLS}`,
        },
      ],
    })}
  />
  <div class="flex flex-1 flex-col items-center py-16">
    <div class="flex w-full max-w-3xl flex-col gap-8">
      <div>
        <a
          href={ROUTES.HOME}
          class="inline-flex text-sm items-center gap-2 text-muted-foreground transition-colors hover:text-foreground"
        >
          <ArrowLeftIcon className="size-4" />
          Back to home
        </a>
      </div>

      <div class="flex flex-col gap-2">
        <h1 class="text-3xl font-semibold tracking-tight">Tools</h1>
        <p class="text-base text-muted-foreground">
          Hand-picked tools, libraries, and resources from the shadcn ecosystem.
          Updated weekly.
        </p>
      </div>

      <div class="grid gap-4 sm:grid-cols-2">
        {
          tools.map((tool) => (
            <ToolCard
              title={tool.data.title}
              description={tool.data.description}
              screenshot={tool.data.image}
              primary={tool.data.url}
            />
          ))
        }
      </div>
    </div>
  </div>
</Layout>

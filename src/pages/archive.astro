---
import Layout from "@/layouts/site.astro";
import { ArrowLeftIcon, LayoutList } from "lucide-react";
import { getCollection } from "astro:content";
import { buttonVariants } from "@/components/ui/button";
import { NEXT_ISSUE_NUMBER, NEXT_ISSUE_DATE, SITE } from "@/constants/site";
import { ROUTES } from "@/constants/routes";

const archive = await getCollection("archive");
const sortedArchive = archive.toSorted((a, b) => b.data.issue - a.data.issue);

const hasArchive = sortedArchive.length > 0;

const formatDate = (date: Date) =>
  date.toLocaleDateString("en-US", {
    day: "numeric",
    month: "long",
    year: "numeric",
  });
---

<Layout
  title="Archive"
  description={`Browse all past issues of ${SITE.NAME}. Every weekly roundup of the best shadcn news, tutorials, projects, and tools.`}
>
  <script
    is:inline
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      itemListElement: [
        {
          "@type": "ListItem",
          position: 1,
          name: "Home",
          item: SITE.URL,
        },
        {
          "@type": "ListItem",
          position: 2,
          name: "Archive",
          item: `${SITE.URL}${ROUTES.ARCHIVE}`,
        },
      ],
    })}
  />
  <div class="flex flex-1 flex-col items-center py-16">
    <div class="flex w-full max-w-3xl flex-col gap-8">
      <div>
        <a
          href={ROUTES.HOME}
          class="inline-flex text-sm items-center gap-2 text-muted-foreground transition-colors hover:text-foreground"
        >
          <ArrowLeftIcon className="size-4" />
          Back to home
        </a>
      </div>

      <div class="flex flex-col gap-2">
        <h1 class="text-3xl font-semibold tracking-tight">Archive</h1>
        <p class="text-base text-muted-foreground">
          Every issue of Shadcn Weekly in one place. Never miss a roundup.
        </p>
      </div>

      {
        hasArchive ? (
          <div class="flex flex-col gap-3">
            {sortedArchive.map((issue) => (
              <a
                href={`${ROUTES.ARCHIVE}/${issue.id}`}
                class="group flex items-start gap-4 rounded-lg border border-border bg-card p-4 transition-colors hover:bg-accent/50"
              >
                <span class="inline-flex size-10 shrink-0 items-center justify-center rounded-full bg-muted text-sm font-semibold text-muted-foreground">
                  #{issue.data.issue}
                </span>
                <div class="flex flex-1 flex-col gap-1">
                  <h2 class="text-base font-semibold leading-tight group-hover:underline">
                    {issue.data.title}
                  </h2>
                  <p class="text-sm text-muted-foreground">
                    {issue.data.description}
                  </p>
                  <time class="text-xs text-muted-foreground/60">
                    {formatDate(issue.data.date)}
                  </time>
                </div>
              </a>
            ))}
          </div>
        ) : (
          <div class="flex flex-col items-center justify-center gap-4 rounded-lg border border-dashed border-border py-20 px-4 text-center">
            <div class="flex size-12 items-center justify-center rounded-full bg-muted">
              <LayoutList className="size-6 text-muted-foreground" />
            </div>
            <div class="flex flex-col gap-1">
              <h2 class="text-lg font-semibold">Coming Soon</h2>
              <p class="max-w-sm text-sm text-muted-foreground text-balance">
                The archive kicks off with Issue #{NEXT_ISSUE_NUMBER} on{" "}
                <span class="font-medium text-foreground">
                  {NEXT_ISSUE_DATE}
                </span>
                . Every week we'll round up the most interesting shadcn
                happenings — new releases, community projects, tutorials, and
                hidden gems you won't find anywhere else.
              </p>
            </div>
            <p class="text-xs text-muted-foreground/60">
              Subscribe to get every issue delivered to your inbox.
            </p>
          </div>
        )
      }
    </div>
  </div>
</Layout>

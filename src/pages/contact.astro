---
import Layout from "@/layouts/site.astro";
import { ArrowLeftIcon } from "lucide-react";
import { SITE } from "@/constants/site";
import { ROUTES } from "@/constants/routes";
import { LINKS } from "@/constants/links";
---

<Layout
  title="Contact"
  description={`Get in touch with ${SITE.NAME}. Reach out via email, Twitter, or Discord for questions, suggestions, or feedback.`}
>
  <script
    is:inline
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      itemListElement: [
        {
          "@type": "ListItem",
          position: 1,
          name: "Home",
          item: SITE.URL,
        },
        {
          "@type": "ListItem",
          position: 2,
          name: "Contact",
          item: `${SITE.URL}${ROUTES.CONTACT}`,
        },
      ],
    })}
  />
  <div class="flex flex-1 flex-col items-center py-16">
    <div class="flex max-w-2xl flex-col gap-6">
      <div>
        <a
          href={ROUTES.HOME}
          class="inline-flex text-sm items-center gap-2 text-muted-foreground transition-colors hover:text-foreground"
        >
          <ArrowLeftIcon className="size-4" />
          Back to home
        </a>
      </div>

      <h1 class="text-3xl font-semibold tracking-tight">Contact</h1>

      <div
        class="flex flex-col gap-4 text-base leading-relaxed text-muted-foreground"
      >
        <p>
          Have a question, suggestion, or want to get in touch? Reach out
          through any of the following:
        </p>
        <ul class="flex flex-col gap-2">
          <li>
            Email:
            <a
              href={`mailto:${LINKS.EMAIL}`}
              class="underline underline-offset-4 hover:text-foreground"
            >
              {LINKS.EMAIL}
            </a>
          </li>
          <li>
            Twitter:
            <a
              href={LINKS.TWITTER}
              target="_blank"
              rel="noopener noreferrer"
              class="underline underline-offset-4 hover:text-foreground"
            >
              {SITE.AUTHOR.TWITTER}
            </a>
          </li>
          <li>
            Discord:
            <a
              href={LINKS.DISCORD}
              target="_blank"
              rel="noopener noreferrer"
              class="underline underline-offset-4 hover:text-foreground"
            >
              Join our server
            </a>
          </li>
        </ul>
      </div>
    </div>
  </div>
</Layout>

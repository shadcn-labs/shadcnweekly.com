---
import Layout from "@/layouts/site.astro";
import { ArrowLeftIcon } from "lucide-react";
---

<Layout
  title="Contact"
  description="Get in touch with Shadcn Weekly. Reach out via email, Twitter, or Discord for questions, suggestions, or feedback."
>
  <script
    is:inline
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      itemListElement: [
        {
          "@type": "ListItem",
          position: 1,
          name: "Home",
          item: "https://shadcnweekly.com",
        },
        {
          "@type": "ListItem",
          position: 2,
          name: "Contact",
          item: "https://shadcnweekly.com/contact",
        },
      ],
    })}
  />
  <div class="flex flex-1 flex-col items-center py-16">
    <div class="flex max-w-2xl flex-col gap-6">
      <a
        href="/"
        class="inline-flex text-sm items-center gap-2 text-muted-foreground transition-colors hover:text-foreground"
      >
        <ArrowLeftIcon className="size-4" />
        Back to home
      </a>
      <h1 class="text-3xl font-semibold tracking-tight">Contact</h1>
      <div
        class="flex flex-col gap-4 text-base leading-relaxed text-muted-foreground"
      >
        <p>
          Have a question, suggestion, or want to get in touch? Reach out
          through any of the following:
        </p>
        <ul class="flex flex-col gap-2">
          <li>
            Email:
            <a
              href="mailto:hello@shadcnweekly.com"
              class="underline underline-offset-4 hover:text-foreground"
            >
              hello@shadcnweekly.com
            </a>
          </li>
          <li>
            Twitter:
            <a
              href="https://x.com/alaymanguy"
              target="_blank"
              rel="noopener noreferrer"
              class="underline underline-offset-4 hover:text-foreground"
            >
              @alaymanguy
            </a>
          </li>
          <li>
            Discord:
            <a
              href="https://discord.com/invite/N6G36KhYK4"
              target="_blank"
              rel="noopener noreferrer"
              class="underline underline-offset-4 hover:text-foreground"
            >
              Join our server
            </a>
          </li>
        </ul>
      </div>
    </div>
  </div>
</Layout>

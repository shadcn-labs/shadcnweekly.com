---
import Layout from "@/layouts/site.astro";
import { SubscribeForm } from "@/components/subscribe-form";
---

<Layout>
  <div
    class="flex flex-1 flex-col items-center justify-center text-center gap-8 py-16"
  >
    <div class="flex flex-col items-center gap-3">
      <span
        class="mb-3 inline-flex items-center gap-2 rounded-full border border-border px-3 py-1 text-xs font-medium text-muted-foreground"
      >
        <span class="relative flex size-2">
          <span
            class="absolute inline-flex size-full animate-ping rounded-full bg-blue-500 opacity-75"
          ></span>
          <span class="relative inline-flex size-2 rounded-full bg-blue-500"
          ></span>
        </span>
        Issue #1 going live on July 13, 2026
      </span>

      <h1 class="text-4xl font-semibold tracking-tight sm:text-5xl">
        Stay up-to-date on shadcn
      </h1>

      <p class="max-w-lg text-base leading-relaxed text-muted-foreground">
        A weekly newsletter with the most interesting shadcn <span
          class="desc-text">News</span
        >,
        <span class="desc-text">Tutorials</span>, <span class="desc-text"
          >Projects</span
        >, and <span class="desc-text">Tools</span>. The easiest way to keep up
        with what's happening in the ecosystem.
      </p>

      <p class="text-base text-muted-foreground opacity-70">
        Once-weekly email, best links, no fluff.
      </p>
    </div>

    <div class="flex w-full max-w-md flex-col items-center gap-2">
      <SubscribeForm client:load />

      <p class="text-sm text-muted-foreground">
        100% free &middot; Delivered every Monday
      </p>
    </div>
  </div>
</Layout>

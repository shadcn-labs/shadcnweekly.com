---
import Layout from "@/layouts/site.astro";
import SubscribeSection from "@/components/subscribe-section.astro";
import { NEXT_ISSUE_NUMBER, NEXT_ISSUE_DATE, SITE } from "@/constants/site";
---

<Layout
  title={`${SITE.NAME} - ${SITE.DESCRIPTION.SHORT}`}
  description={`${SITE.DESCRIPTION.LONG} Stay up-to-date with what's happening in the shadcn ecosystem.`}
>
  <div
    class="flex flex-1 flex-col items-center justify-center text-center gap-3 py-16"
  >
    <div class="flex flex-col items-center gap-3">
      <span
        class="mb-3 inline-flex items-center gap-2 rounded-full border border-border px-3 py-1 text-xs font-medium text-muted-foreground"
      >
        <span class="relative flex size-2">
          <span
            class="absolute inline-flex size-full animate-ping rounded-full bg-blue-500 opacity-75"
          ></span>
          <span class="relative inline-flex size-2 rounded-full bg-blue-500"
          ></span>
        </span>
        Issue #{NEXT_ISSUE_NUMBER} going live on {NEXT_ISSUE_DATE}
      </span>

      <h1 class="text-4xl font-semibold tracking-tight sm:text-5xl">
        Stay up-to-date on shadcn
      </h1>
    </div>

    <SubscribeSection formClass="mt-5" />
  </div>
</Layout>

---
import Layout from "@/layouts/site.astro";
import { ArrowLeftIcon } from "lucide-react";
import { getCollection } from "astro:content";
import { SITE } from "@/constants/site";
import { ROUTES } from "@/constants/routes";

const issues = await getCollection("archive");
const sortedIssues = issues.toSorted((a, b) => b.data.issue - a.data.issue);

const formatDate = (date: Date) =>
  date.toLocaleDateString("en-US", {
    day: "numeric",
    month: "long",
    year: "numeric",
  });
---

<Layout
  title="Issues Archive"
  description="Browse every issue of Shadcn Weekly—curated shadcn news, tutorials, projects, and tools."
>
  <script
    is:inline
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      itemListElement: [
        {
          "@type": "ListItem",
          position: 1,
          name: "Home",
          item: SITE.URL,
        },
        {
          "@type": "ListItem",
          position: 2,
          name: "Issues",
          item: `${SITE.URL}${ROUTES.ISSUES}`,
        },
      ],
    })}
  />

  <div class="flex flex-1 flex-col items-center py-16">
    <div class="flex w-full max-w-3xl flex-col gap-8">
      <div>
        <a
          href="/"
          class="inline-flex items-center gap-2 text-sm text-muted-foreground transition-colors hover:text-foreground"
        >
          <ArrowLeftIcon className="size-4" />
          Back to home
        </a>
      </div>

      <div class="flex flex-col gap-2">
        <h1 class="text-3xl font-semibold tracking-tight">
          Newsletter Archive
        </h1>
        <p class="text-base text-muted-foreground">
          Every issue of Shadcn Weekly in one place. Never miss a roundup.
        </p>
      </div>

      <div class="flex flex-col gap-3">
        {
          sortedIssues.map((issue) => (
            <a
              href={`/issues/${issue.id}`}
              class="group flex items-start gap-4 rounded-lg border border-border bg-card p-4 transition-colors hover:bg-accent/50"
            >
              <span class="inline-flex size-10 shrink-0 items-center justify-center rounded-full bg-muted text-sm font-semibold text-muted-foreground">
                #{issue.data.issue}
              </span>
              <div class="flex flex-1 flex-col gap-1">
                <h2 class="text-base font-semibold leading-tight group-hover:underline">
                  {issue.data.title}
                </h2>
                <p class="text-sm text-muted-foreground">
                  {issue.data.description}
                </p>
                <time class="text-xs text-muted-foreground/60">
                  {formatDate(issue.data.date)}
                </time>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </div>
</Layout>
